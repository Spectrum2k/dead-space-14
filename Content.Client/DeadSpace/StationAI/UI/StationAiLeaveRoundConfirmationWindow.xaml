<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'station-ai-leave-round-confirmation-title'}"
                      Resizable="False">
    <BoxContainer Orientation="Vertical" SetWidth="520" Margin="18 14 18 16">
        <Label Name="WarningTitle"
               StyleClasses="LabelHeading"
               FontColorOverride="#ff5f5f"
               Margin="0 0 0 8"/>
        <RichTextLabel Name="WarningBody"
                       Margin="0 0 0 18"/>
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="12">
            <Button Name="CancelButton"
                    Text="{Loc 'station-ai-leave-round-confirmation-cancel'}"
                    HorizontalExpand="True"
                    SizeFlagsStretchRatio="1"/>
            <Control HorizontalExpand="True"/>
            <Button Name="ConfirmButton"
                    Text="{Loc 'station-ai-leave-round-confirmation-confirm'}"
                    HorizontalExpand="True"
                    SizeFlagsStretchRatio="1"
                    StyleClasses="negative"/>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
